#!/bin/sh
# Waybar volume widget — works with wpctl (Linux) or sndioctl (OpenBSD)
if command -v wpctl > /dev/null 2>&1; then
    wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{
        muted = ($3 == "[MUTED]")
        vol = int($2 * 100)
        if (muted) printf "{\"text\":\"󰝟\",\"class\":\"muted\",\"tooltip\":\"Muted\"}\n"
        else printf "{\"text\":\"󰕾\",\"tooltip\":\"%d%%\"}\n", vol, vol
    }'
else
    level=$(sndioctl -n output.level 2>/dev/null || echo 0)
    mute=$(sndioctl -n output.mute 2>/dev/null || echo 0)
    vol=$(awk "BEGIN{printf \"%d\", $level*100}")
    if [ "$mute" = "1" ]; then
        printf '{"text":"󰝟","class":"muted","tooltip":"Muted"}\n'
    else
        printf '{"text":"󰕾","tooltip":"%d%%"}\n' "$vol" "$vol"
    fi
fi
