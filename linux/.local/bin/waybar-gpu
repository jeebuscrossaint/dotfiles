#!/bin/sh
# RTX 4070 state for waybar — a PURE sysfs read of the PM runtime state.
# Deliberately does NOT call nvidia-smi: querying the GPU wakes it and resets
# its autosuspend timer, so polling nvidia-smi would keep the dGPU awake forever
# and torch the battery. Reading runtime_status is a kernel-state read that
# never touches the device, so this module is free and never costs the sleep.
#   suspended = D3cold (~0W)   |   active = something's using it (or not re-slept)
st=$(cat /sys/bus/pci/devices/0000:01:00.0/power/runtime_status 2>/dev/null)
if [ "$st" = "suspended" ]; then
    printf '{"text":"󰤄","tooltip":"RTX 4070: asleep (D3cold, ~0W)","class":"asleep"}\n'
else
    printf '{"text":"󰢮","tooltip":"RTX 4070: awake — something is using it (or it has not re-suspended yet). Run nvidia-smi to see what.","class":"active"}\n'
fi
