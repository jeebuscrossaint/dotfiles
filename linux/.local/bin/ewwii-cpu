#!/usr/bin/env bash
# CPU usage % (short delta sample from /proc/stat) for the ewwii bar.
read -r _ a b c idle rest < /proc/stat
t1=$((a + b + c + idle)); i1=$idle
sleep 0.25
read -r _ a b c idle rest < /proc/stat
t2=$((a + b + c + idle)); i2=$idle
dt=$((t2 - t1)); di=$((i2 - i1))
[ "$dt" -le 0 ] && { echo 0; exit; }
echo $(( (100 * (dt - di)) / dt ))
