#!/bin/sh
# Offload a single app to the NVIDIA dGPU (wakes the RTX 4070 from D3cold),
# while the desktop stays composited on the Intel iGPU. macOS-style on-demand
# discrete GPU. Usage:  prime-run <command>   e.g.  prime-run steam
#   Steam launch options:  prime-run %command%
export __NV_PRIME_RENDER_OFFLOAD=1
export __NV_PRIME_RENDER_OFFLOAD_PROVIDER=NVIDIA-G0
export __GLX_VENDOR_LIBRARY_NAME=nvidia
export __VK_LAYER_NV_optimus=NVIDIA_only
export VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/nvidia_icd.json
exec "$@"
