#!/bin/sh
# Pending updates for waybar. Deliberately run at a LONG interval (see config)
# to stay battery/network-friendly: checkupdates syncs a temp db and paru -Qua
# hits the AUR RPC. Empty text when up to date -> waybar hides the module.
off=$(checkupdates 2>/dev/null | wc -l)
aur=$(paru -Qua 2>/dev/null | wc -l)
tot=$((off + aur))
if [ "$tot" -eq 0 ]; then
    printf '{"text":"","tooltip":"System up to date"}\n'
else
    printf '{"text":"󰚰 %s","tooltip":"%s repo + %s AUR update(s) — click to update","class":"has-updates"}\n' "$tot" "$off" "$aur"
fi
