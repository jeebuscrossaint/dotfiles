#!/usr/bin/env bash
# Pick a random coat scheme, apply it everywhere, and notify. (Hyprland keybind.)
coat random -y >/dev/null 2>&1   # coat's ashell module restarts ashell itself
scheme=$(grep -m1 '^scheme:' "$HOME/.config/coat/coat.yaml" | awk '{print $2}')
command -v notify-send >/dev/null && notify-send -t 2000 "󰏘  Theme" "switched to $scheme"
