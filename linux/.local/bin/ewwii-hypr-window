#!/usr/bin/env bash
# Stream the focused window title, updating instantly on events (for ewwii Listen).
[ -n "$HYPRLAND_INSTANCE_SIGNATURE" ] || exit 0
sock="$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"
cur() { hyprctl activewindow -j 2>/dev/null | jq -r .title 2>/dev/null | sed 's/^null$//' | cut -c1-48; }
cur
command -v socat >/dev/null || exit 0
socat -U - "UNIX-CONNECT:$sock" 2>/dev/null | while read -r line; do
  case "${line%%>>*}" in
    activewindow|activewindowv2|closewindow|openwindow|workspacev2) cur ;;
  esac
done
