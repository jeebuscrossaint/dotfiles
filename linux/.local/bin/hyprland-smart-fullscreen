#!/usr/bin/env bash
# Smart fullscreen for Hyprland: when a workspace holds exactly one tiled window,
# auto-maximize it (fullscreen mode 1 — fills the work area, keeps the bar, no
# border/shadow). When a second window appears, the maximized one drops back to
# tiling. Runs as a daemon (exec-once in hyprland.conf) on Hyprland's event
# socket. Deps: socat, jq.

[ -n "$HYPRLAND_INSTANCE_SIGNATURE" ] || exit 0
command -v socat >/dev/null && command -v jq >/dev/null || exit 0

# Single instance only (avoids duplicate maximize toggles / flicker).
pidfile="${XDG_RUNTIME_DIR:-/tmp}/hyprland-smart-fullscreen.pid"
if [ -f "$pidfile" ] && kill -0 "$(cat "$pidfile" 2>/dev/null)" 2>/dev/null; then
    exit 0
fi
echo $$ > "$pidfile"
trap 'rm -f "$pidfile"' EXIT

sock="$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"

adjust() {
    local aw ws fs n fsaddr active
    aw=$(hyprctl activeworkspace -j 2>/dev/null) || return 0
    ws=$(printf '%s' "$aw" | jq -r '.id')
    fs=$(printf '%s' "$aw" | jq -r '.hasfullscreen')
    n=$(hyprctl clients -j 2>/dev/null \
        | jq "[.[] | select(.workspace.id == $ws and .floating == false and .mapped == true)] | length")

    if [ "$n" = "1" ] && [ "$fs" = "false" ]; then
        # lone tiled window → maximize it (it is the focused one)
        hyprctl dispatch fullscreen 1 >/dev/null 2>&1
    elif [ "${n:-0}" -gt 1 ] 2>/dev/null && [ "$fs" = "true" ]; then
        # a second window joined while one was maximized → drop it back to tiling,
        # targeting the maximized window by address and restoring focus after.
        fsaddr=$(hyprctl clients -j 2>/dev/null \
            | jq -r ".[] | select(.workspace.id==$ws and (.fullscreen != 0 and .fullscreen != false)) | .address" | head -1)
        active=$(hyprctl activewindow -j 2>/dev/null | jq -r '.address')
        [ -n "$fsaddr" ] && [ "$fsaddr" != "null" ] && hyprctl --batch \
            "dispatch focuswindow address:$fsaddr ; dispatch fullscreen 1 ; dispatch focuswindow address:$active" >/dev/null 2>&1
    fi
    return 0
}

adjust   # handle the window that already exists at startup

socat -U - "UNIX-CONNECT:$sock" 2>/dev/null | while read -r line; do
    case "${line%%>>*}" in
        openwindow|closewindow|movewindow|movewindowv2|changefloatingmode|workspace|workspacev2|activewindowv2|focusedmon|focusedmonv2) adjust ;;
    esac
done
