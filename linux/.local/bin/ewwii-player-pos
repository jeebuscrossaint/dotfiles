#!/usr/bin/env bash
# Output the current track's playback position as a percentage (0-100) for the
# ewwii music widget's progress bar. Uses playerctl (position in seconds,
# mpris:length in microseconds).
pos=$(playerctl position 2>/dev/null)
len=$(playerctl metadata mpris:length 2>/dev/null)
if [ -z "$pos" ] || [ -z "$len" ] || [ "${len%.*}" -le 0 ] 2>/dev/null; then
    echo 0
    exit 0
fi
awk "BEGIN { p = $pos * 1000000 / $len * 100; if (p < 0) p = 0; if (p > 100) p = 100; printf \"%.1f\", p }"
