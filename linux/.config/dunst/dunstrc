# Dunst configuration
# Generated by coat
# Theme: Square
# Author: FredHappyface (https://github.com/fredHappyface)
# Variant: dark

[global]
    # Display
    monitor = 0
    follow = mouse

    # Geometry
    width = (0, 400)
    height = 300
    origin = top-right
    offset = 10x50
    scale = 0
    notification_limit = 5

    # Progress bar
    progress_bar = true
    progress_bar_height = 4
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 2

    # Text
    font = UbuntuMono Nerd Font Mono 11
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    word_wrap = yes

    # Icons
    enable_recursive_icon_lookup = true
    icon_theme = Papirus-Dark,Adwaita
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48

    # History
    sticky_history = yes
    history_length = 20

    # Misc/Advanced
    dmenu = /usr/bin/rofi -dmenu -p dunst
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 10
    corners = all
    ignore_dbusclose = false
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

    # Frame
    frame_width = 1
    frame_color = "#141414"
    separator_color = frame
    separator_height = 1
    padding = 12
    horizontal_padding = 14
    text_icon_padding = 10
    gap_size = 6

[urgency_low]
    background = "#1A1A1A"
    foreground = "#838383"
    frame_color = "#4B4B4B"
    timeout = 4

[urgency_normal]
    background = "#1A1A1A"
    foreground = "#E2E2E2"
    frame_color = "#141414"
    timeout = 6

[urgency_critical]
    background = "#1A1A1A"
    foreground = "#E9897C"
    frame_color = "#E9897C"
    timeout = 0
